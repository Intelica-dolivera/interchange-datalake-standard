# ITX AWS Pipeline - Variables de entorno
# 1. Copiar: cp .env.example .env
# 2. Completar valores segun ambiente
# 3. NUNCA commitear .env a GitHub

# Cuenta AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=<tu-account-id>
ENVIRONMENT=dev

# S3 Buckets
S3_BUCKET_LANDING=itx-landing-dev
S3_BUCKET_STAGING=itx-staging-dev
S3_BUCKET_OPERATIONAL=itx-operational-dev
S3_BUCKET_ARCHIVE=itx-archive-dev
S3_BUCKET_REFERENCE=itx-reference-dev

# DynamoDB
DYNAMODB_TABLE_FILE_CONTROL=itx-file-control
DYNAMODB_TABLE_FILE_PATTERN=itx-file-pattern
DYNAMODB_TABLE_VISA_FIELDS=itx-visa-fields
DYNAMODB_TABLE_CLIENT=itx-client

# Step Functions
STEP_FUNCTION_ARN=arn:aws:states:us-east-1:<account-id>:stateMachine:itx-main-orchestrator

# Lambda
CHUNK_SIZE_MB=64
FLUSH_BATCH_SIZE=500000
EXTRACT_CHUNK_SIZE=100000
CLEAN_CHUNK_SIZE=100000

# Glue
GLUE_SCRIPTS_PATH=s3://itx-staging-dev/scripts/
